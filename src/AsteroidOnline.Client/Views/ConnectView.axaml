<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsteroidOnline.Client.ViewModels"
             xmlns:conv="using:AsteroidOnline.Client.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="AsteroidOnline.Client.Views.ConnectView"
             x:DataType="vm:ConnectViewModel"
             Background="#0A0A1A">

  <!-- Centrage vertical et horizontal du panneau de connexion -->
  <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="420">
    <StackPanel Spacing="0">

      <!-- ══ Titre ══════════════════════════════════════════════════════════ -->
      <StackPanel HorizontalAlignment="Center" Margin="0,0,0,36">
        <TextBlock Text="ASTEROID ONLINE"
                   FontSize="40" FontWeight="Bold"
                   Foreground="#00CFFF"
                   HorizontalAlignment="Center"
                   LetterSpacing="4" />
        <TextBlock Text="Battle Royal Multijoueur"
                   FontSize="14"
                   Foreground="#557799"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,0" />
      </StackPanel>

      <!-- ══ Champ Pseudo (US-01) ══════════════════════════════════════════ -->
      <TextBlock Text="PSEUDO" Foreground="#88AACC" FontSize="11"
                 FontWeight="SemiBold" LetterSpacing="2" Margin="0,0,0,6" />
      <TextBox Text="{Binding Pseudo}"
               Watermark="Votre pseudo (1-20 caractères)"
               MaxLength="20"
               Background="#111827"
               Foreground="White"
               BorderBrush="#1E3A5F"
               CornerRadius="4"
               Padding="10,8" />

      <!-- ══ Adresse + Port serveur (US-01) ══════════════════════════════ -->
      <TextBlock Text="SERVEUR" Foreground="#88AACC" FontSize="11"
                 FontWeight="SemiBold" LetterSpacing="2" Margin="0,16,0,6" />
      <Grid ColumnDefinitions="*,8,90">
        <TextBox Grid.Column="0"
                 Text="{Binding ServerAddress}"
                 Watermark="127.0.0.1"
                 Background="#111827" Foreground="White"
                 BorderBrush="#1E3A5F" CornerRadius="4" Padding="10,8" />
        <TextBox Grid.Column="2"
                 Text="{Binding ServerPort}"
                 Watermark="7777"
                 Background="#111827" Foreground="White"
                 BorderBrush="#1E3A5F" CornerRadius="4" Padding="10,8" />
      </Grid>

      <!-- ══ Sélecteur de couleur de vaisseau (US-05) ══════════════════════ -->
      <TextBlock Text="COULEUR DU VAISSEAU" Foreground="#88AACC" FontSize="11"
                 FontWeight="SemiBold" LetterSpacing="2" Margin="0,16,0,8" />

      <!-- Liste horizontale des options de couleur -->
      <ListBox ItemsSource="{Binding AvailableColors}"
               SelectedItem="{Binding SelectedColorOption}"
               Background="Transparent"
               BorderThickness="0">
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel Orientation="Horizontal" />
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:PlayerColorOption">
            <Border CornerRadius="4" Padding="10,6" Margin="3"
                    Background="#111827" BorderThickness="2"
                    BorderBrush="{Binding HexColor, Converter={x:Static conv:StringToBrushConverter.Instance}}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <!-- Cercle coloré représentant la couleur du vaisseau -->
                <Ellipse Width="14" Height="14"
                         Fill="{Binding HexColor, Converter={x:Static conv:StringToBrushConverter.Instance}}" />
                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <!-- ══ Aperçu du vaisseau coloré (US-05) ═════════════════════════════ -->
      <Border Background="#0D1520" CornerRadius="6" Padding="12" Margin="0,10,0,0"
              HorizontalAlignment="Center" Width="120" Height="80">
        <Canvas Width="60" Height="60" HorizontalAlignment="Center" VerticalAlignment="Center">
          <!-- Triangle vaisseau : pointe vers le haut -->
          <Polygon Points="30,4 8,52 30,42 52,52"
                   Fill="{Binding SelectedColorOption.HexColor, Converter={x:Static conv:StringToBrushConverter.Instance}}"
                   Stroke="#FFFFFF22" StrokeThickness="1" />
        </Canvas>
      </Border>

      <!-- ══ Bouton de connexion ════════════════════════════════════════════ -->
      <Button Content="SE CONNECTER"
              Command="{Binding ConnectCommand}"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              Background="#00CFFF"
              Foreground="#0A0A1A"
              FontWeight="Bold"
              FontSize="15"
              Padding="0,14"
              CornerRadius="4"
              Margin="0,20,0,0" />

      <!-- ══ Indicateur de statut de connexion (US-03) ═════════════════════ -->
      <TextBlock Text="{Binding StatusMessage}"
                 Foreground="{Binding ConnectionStatus,
                     Converter={x:Static conv:ConnectionStatusToBrushConverter.Instance}}"
                 HorizontalAlignment="Center"
                 FontSize="13"
                 Margin="0,10,0,0"
                 IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

    </StackPanel>
  </Grid>
</UserControl>
