<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsteroidOnline.Client.ViewModels"
             xmlns:conv="using:AsteroidOnline.Client.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="AsteroidOnline.Client.Views.ConnectView"
             x:DataType="vm:ConnectViewModel"
             Background="#070A12">

  <Grid>
    <Border Width="520"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Padding="26"
            CornerRadius="12"
            Background="#BE0A1220"
            BorderBrush="#55FFB95F"
            BorderThickness="1">
      <StackPanel Spacing="10">
        <TextBlock Text="ASTEROID STRIKE CO-OP"
                   FontSize="38"
                   FontWeight="Bold"
                   Foreground="#FFCC6F"
                   HorizontalAlignment="Center"
                   LetterSpacing="2.8" />
        <TextBlock Text="Arcade survival • équipe jusqu'à 20 pilotes"
                   FontSize="14"
                   Foreground="#9CC6EB"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,6" />

        <TextBlock Text="PSEUDO" Foreground="#91B5D4" FontSize="11" FontWeight="SemiBold" LetterSpacing="2" />
        <TextBox Text="{Binding Pseudo}"
                 Watermark="Votre pseudo (1-20 caractères)"
                 MaxLength="20"
                 Background="#101B2D"
                 Foreground="#EEF6FF"
                 BorderBrush="#2F5378"
                 CornerRadius="6"
                 Padding="10,8" />

        <TextBlock Text="SERVEUR" Foreground="#91B5D4" FontSize="11" FontWeight="SemiBold" LetterSpacing="2" Margin="0,8,0,0" />
        <Grid ColumnDefinitions="*,8,95">
          <TextBox Grid.Column="0"
                   Text="{Binding ServerAddress}"
                   Watermark="127.0.0.1"
                   Background="#101B2D"
                   Foreground="#EEF6FF"
                   BorderBrush="#2F5378"
                   CornerRadius="6"
                   Padding="10,8" />
          <TextBox Grid.Column="2"
                   Text="{Binding ServerPort}"
                   Watermark="7777"
                   Background="#101B2D"
                   Foreground="#EEF6FF"
                   BorderBrush="#2F5378"
                   CornerRadius="6"
                   Padding="10,8" />
        </Grid>

        <TextBlock Text="COULEUR DU VAISSEAU" Foreground="#91B5D4" FontSize="11" FontWeight="SemiBold" LetterSpacing="2" Margin="0,8,0,0" />
        <ListBox ItemsSource="{Binding AvailableColors}"
                 SelectedItem="{Binding SelectedColorOption}"
                 Background="Transparent"
                 BorderThickness="0">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:PlayerColorOption">
              <Border CornerRadius="6"
                      Padding="10,6"
                      Margin="4"
                      Background="#111E32"
                      BorderThickness="1.5"
                      BorderBrush="{Binding HexColor, Converter={x:Static conv:StringToBrushConverter.Instance}}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Ellipse Width="14" Height="14"
                           Fill="{Binding HexColor, Converter={x:Static conv:StringToBrushConverter.Instance}}" />
                  <TextBlock Text="{Binding Name}" Foreground="#EEF6FF" FontSize="13" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Button Content="REJOINDRE LE LOBBY"
                Command="{Binding ConnectCommand}"
                HorizontalAlignment="Stretch"
                FontWeight="Bold"
                FontSize="16"
                Padding="0,14"
                CornerRadius="6"
                Background="#FFCC59"
                Foreground="#101620"
                Margin="0,8,0,0" />

        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="{Binding ConnectionStatus, Converter={x:Static conv:ConnectionStatusToBrushConverter.Instance}}"
                   HorizontalAlignment="Center"
                   FontSize="13"
                   Margin="0,6,0,0"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
