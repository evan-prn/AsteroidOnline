<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsteroidOnline.Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="620"
             x:Class="AsteroidOnline.Client.Views.GameOverView"
             x:DataType="vm:GameOverViewModel"
             Background="#070A12">

  <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="560">
    <Border CornerRadius="12"
            Background="#C00A121F"
            BorderBrush="#55FFB964"
            BorderThickness="1"
            Padding="30">
      <StackPanel Spacing="12">
        <TextBlock Text="MISSION TERMINÉE"
                   FontSize="38"
                   FontWeight="Bold"
                   Foreground="#FFCD72"
                   HorizontalAlignment="Center"
                   LetterSpacing="2.4" />

        <TextBlock Text="{Binding WinnerName, StringFormat=Leader : {0}}"
                   IsVisible="{Binding ShowWinner}"
                   FontSize="21"
                   Foreground="#E8F4FF"
                   HorizontalAlignment="Center" />

        <TextBlock Text="{Binding FinalScore, StringFormat=Score personnel : {0}}"
                   FontSize="20"
                   Foreground="#A9D6FF"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,0" />

        <Button Content="RETOUR AU LOBBY"
                Command="{Binding ReturnToLobbyCommand}"
                HorizontalAlignment="Stretch"
                FontWeight="Bold"
                FontSize="16"
                Padding="0,14"
                CornerRadius="6"
                Margin="0,12,0,0"
                Background="#FFCC59"
                Foreground="#101620" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
