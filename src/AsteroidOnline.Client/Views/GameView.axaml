<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsteroidOnline.Client.ViewModels"
             xmlns:conv="using:AsteroidOnline.Client.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="AsteroidOnline.Client.Views.GameView"
             x:DataType="vm:GameViewModel"
             Background="#070A12"
             Focusable="True">

  <Grid>
    <Canvas x:Name="GameCanvas"
            Background="#05060D"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" />

    <Panel IsHitTestVisible="False">
      <Border HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Margin="16"
              Padding="12,8"
              CornerRadius="8"
              Background="#A10C1626"
              BorderBrush="#55FFB84D"
              BorderThickness="1">
        <StackPanel Spacing="4">
          <TextBlock Text="SQUAD STATUS"
                     FontSize="11"
                     Foreground="#FFD47B"
                     FontWeight="Bold"
                     LetterSpacing="1.8" />
          <TextBlock FontSize="14" Foreground="#E7F0FF">
            <TextBlock.Text>
              <MultiBinding StringFormat="{}{0} pilote(s) actif(s)">
                <Binding Path="AlivePlayersCount" />
              </MultiBinding>
            </TextBlock.Text>
          </TextBlock>
          <TextBlock FontSize="14" Foreground="#AEE2FF">
            <TextBlock.Text>
              <MultiBinding StringFormat="Vies : {0}">
                <Binding Path="MyLives" />
              </MultiBinding>
            </TextBlock.Text>
          </TextBlock>
          <TextBlock FontSize="12"
                     Foreground="#FFF174"
                     IsVisible="{Binding IsInvulnerable}">
            <TextBlock.Text>
              <MultiBinding StringFormat="Invulnérable : {0:0.0}s">
                <Binding Path="InvulnerabilitySecondsRemaining" />
              </MultiBinding>
            </TextBlock.Text>
          </TextBlock>
        </StackPanel>
      </Border>

      <Border HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="16"
              Padding="12,8"
              CornerRadius="8"
              Background="#A1091321"
              BorderBrush="#5575C3FF"
              BorderThickness="1">
        <StackPanel Spacing="2" HorizontalAlignment="Right">
          <TextBlock FontSize="14" Foreground="#DDEBFF" HorizontalAlignment="Right">
            <TextBlock.Text>
              <MultiBinding StringFormat="Score : {0}">
                <Binding Path="MyScore" />
              </MultiBinding>
            </TextBlock.Text>
          </TextBlock>
          <TextBlock FontSize="12" Foreground="#B6CAEB" HorizontalAlignment="Right">
            <TextBlock.Text>
              <MultiBinding StringFormat="Rang coop : #{0}">
                <Binding Path="MyRank" />
              </MultiBinding>
            </TextBlock.Text>
          </TextBlock>
          <TextBlock FontSize="12" Foreground="#88FFAA" HorizontalAlignment="Right">
            <TextBlock.Text>
              <MultiBinding StringFormat="FPS {0}">
                <Binding Path="Fps" />
              </MultiBinding>
            </TextBlock.Text>
          </TextBlock>
          <TextBlock FontSize="12" Foreground="#72CCFF" HorizontalAlignment="Right">
            <TextBlock.Text>
              <MultiBinding StringFormat="Ping {0} ms">
                <Binding Path="NetworkLatencyMs" />
              </MultiBinding>
            </TextBlock.Text>
          </TextBlock>
        </StackPanel>
      </Border>

      <Border HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Margin="0,16,0,0"
              Padding="14,8"
              CornerRadius="10"
              Background="#C01D0F1D"
              BorderBrush="#66FF6767"
              BorderThickness="1"
              IsVisible="{Binding ShowEliminationFeed}">
        <TextBlock Text="{Binding EliminationFeedText}"
                   Foreground="#FFE3E3"
                   FontSize="15"
                   FontWeight="SemiBold" />
      </Border>

      <Border HorizontalAlignment="Left"
              VerticalAlignment="Bottom"
              Margin="16"
              Padding="10,8"
              CornerRadius="8"
              Background="#A10A1523"
              BorderBrush="#553ECFFF"
              BorderThickness="1">
        <StackPanel Spacing="4" Width="170">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="DASH" FontSize="11" FontWeight="Bold" LetterSpacing="2"
                       Foreground="{Binding IsDashReady,
                           Converter={x:Static conv:BoolToColorConverter.Instance},
                           ConverterParameter='#43DAFF|#56697C'}" />
            <TextBlock Text="[SHIFT / E]" FontSize="11" Foreground="#88AFCF" />
          </StackPanel>

          <Border Height="7" CornerRadius="3" Background="#1F3B58">
            <Border HorizontalAlignment="Left"
                    Height="7"
                    CornerRadius="3"
                    Width="{Binding DashCooldownProgress,
                        Converter={x:Static conv:ProgressToWidthConverter.Instance},
                        ConverterParameter='166'}"
                    Background="{Binding IsDashReady,
                        Converter={x:Static conv:BoolToColorConverter.Instance},
                        ConverterParameter='#00D4FF|#30516E'}" />
          </Border>
        </StackPanel>
      </Border>

      <Border HorizontalAlignment="Center"
              VerticalAlignment="Bottom"
              Margin="16"
              Padding="10,8"
              CornerRadius="8"
              Background="#86090E1B"
              BorderBrush="#33FFFFFF"
              BorderThickness="1">
        <StackPanel Spacing="2">
          <TextBlock Text="WASD / ZQSD / Flèches : piloter" FontSize="12" Foreground="#A4C4E6" />
          <TextBlock Text="ESPACE / F : tir coopératif" FontSize="12" Foreground="#A4C4E6" />
          <TextBlock Text="Radar : coin bas droit" FontSize="12" Foreground="#FFCF7F" />
        </StackPanel>
      </Border>
    </Panel>
  </Grid>
</UserControl>
