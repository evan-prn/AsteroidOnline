<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsteroidOnline.Client.ViewModels"
             xmlns:shared="using:AsteroidOnline.Shared.Packets"
             xmlns:conv="using:AsteroidOnline.Client.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="AsteroidOnline.Client.Views.LobbyView"
             x:DataType="vm:LobbyViewModel"
             Background="#080B14">

  <Grid RowDefinitions="Auto,*,Auto" Margin="28">
    <Border Grid.Row="0"
            Padding="18,14"
            CornerRadius="10"
            Background="#A0081220"
            BorderBrush="#55F7BF59"
            BorderThickness="1">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="5">
          <TextBlock Text="CO-OP LOBBY"
                     FontSize="34"
                     FontWeight="Bold"
                     LetterSpacing="3"
                     Foreground="#FFC96A" />
          <TextBlock FontSize="13" Foreground="#BCD6F1">
            <TextBlock.Text>
              <MultiBinding StringFormat="{}{0} pilote(s) prêt(s)">
                <Binding Path="PlayerCount" />
              </MultiBinding>
            </TextBlock.Text>
          </TextBlock>
          <TextBlock FontSize="13" Foreground="#9CC0E2">
            <TextBlock.Text>
              <MultiBinding StringFormat="Hôte : {0}">
                <Binding Path="HostName" />
              </MultiBinding>
            </TextBlock.Text>
          </TextBlock>
        </StackPanel>

        <Border Grid.Column="1"
                IsVisible="{Binding CanStartGame}"
                Background="#1A2E1B"
                BorderBrush="#66B5FF7A"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,6"
                VerticalAlignment="Top">
          <TextBlock Text="COMMANDER ACCESS"
                     FontSize="11"
                     FontWeight="Bold"
                     Foreground="#BCFF8B"
                     LetterSpacing="1.4" />
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Margin="0,16,0,0"
            Background="#C00B1322"
            CornerRadius="10"
            Padding="14"
            BorderBrush="#445FA2E0"
            BorderThickness="1">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Players}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="shared:LobbyPlayerInfo">
              <Border Background="#A1111F34"
                      CornerRadius="8"
                      Padding="12,10"
                      Margin="0,0,0,8"
                      BorderBrush="#304B79"
                      BorderThickness="1">
                <Grid ColumnDefinitions="Auto,12,*,Auto">
                  <Canvas Grid.Column="0" Width="34" Height="34">
                    <Polygon Points="17,2 4,30 17,23 30,30"
                             Fill="{Binding ColorHex, Converter={x:Static conv:StringToBrushConverter.Instance}}"
                             Stroke="#FFFFFF22"
                             StrokeThickness="1" />
                  </Canvas>

                  <StackPanel Grid.Column="2"
                              Orientation="Horizontal"
                              Spacing="8"
                              VerticalAlignment="Center">
                    <TextBlock Text="{Binding Pseudo}" FontSize="17" Foreground="#EAF4FF" />
                    <Border IsVisible="{Binding IsHost}"
                            Background="#264D2D"
                            BorderBrush="#66B8FF83"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="6,2">
                      <TextBlock Text="HÔTE" FontSize="11" FontWeight="Bold" Foreground="#CBFFAB" />
                    </Border>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <Border Grid.Row="2"
            Margin="0,16,0,0"
            HorizontalAlignment="Center"
            Padding="8"
            CornerRadius="10"
            Background="#99060C19"
            BorderBrush="#44FFFFFF"
            BorderThickness="1">
      <StackPanel Spacing="8" HorizontalAlignment="Center">
        <TextBlock Text="{Binding CountdownText}"
                   FontSize="48"
                   FontWeight="Bold"
                   Foreground="#56E4FF"
                   HorizontalAlignment="Center" />

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="4"
                    IsVisible="{Binding IsCountingDown}">
          <Border Width="42" Height="7" CornerRadius="4"
                  Background="{Binding CountdownSeconds, Converter={x:Static conv:CountdownSegmentConverter.Instance},
                               ConverterParameter='0'}" />
          <Border Width="42" Height="7" CornerRadius="4"
                  Background="{Binding CountdownSeconds, Converter={x:Static conv:CountdownSegmentConverter.Instance},
                               ConverterParameter='1'}" />
          <Border Width="42" Height="7" CornerRadius="4"
                  Background="{Binding CountdownSeconds, Converter={x:Static conv:CountdownSegmentConverter.Instance},
                               ConverterParameter='2'}" />
          <Border Width="42" Height="7" CornerRadius="4"
                  Background="{Binding CountdownSeconds, Converter={x:Static conv:CountdownSegmentConverter.Instance},
                               ConverterParameter='3'}" />
          <Border Width="42" Height="7" CornerRadius="4"
                  Background="{Binding CountdownSeconds, Converter={x:Static conv:CountdownSegmentConverter.Instance},
                               ConverterParameter='4'}" />
        </StackPanel>

        <Button Content="START GAME"
                Command="{Binding StartGameCommand}"
                IsVisible="{Binding CanStartGame}"
                HorizontalAlignment="Center"
                FontSize="16"
                FontWeight="Bold"
                Padding="28,10"
                Background="#FFC44F"
                Foreground="#0D121D"
                CornerRadius="6" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
