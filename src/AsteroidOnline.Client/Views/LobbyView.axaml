<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AsteroidOnline.Client.ViewModels"
             xmlns:shared="using:AsteroidOnline.Shared.Packets"
             xmlns:conv="using:AsteroidOnline.Client.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="AsteroidOnline.Client.Views.LobbyView"
             x:DataType="vm:LobbyViewModel"
             Background="#0A0A1A">

  <Grid RowDefinitions="Auto,*,Auto" Margin="40">

    <!-- ══ En-tête ══════════════════════════════════════════════════════════ -->
    <StackPanel Grid.Row="0" Margin="0,0,0,24">
      <TextBlock Text="LOBBY" FontSize="32" FontWeight="Bold"
                 Foreground="#00CFFF" LetterSpacing="4" />
      <TextBlock FontSize="14" Foreground="#557799" Margin="0,4,0,0">
        <TextBlock.Text>
          <MultiBinding StringFormat="{}{0} joueur(s) connecté(s)">
            <Binding Path="PlayerCount" />
          </MultiBinding>
        </TextBlock.Text>
      </TextBlock>
      <TextBlock FontSize="13" Foreground="#9FC3E8" Margin="0,6,0,0">
        <TextBlock.Text>
          <MultiBinding StringFormat="Hôte : {0}">
            <Binding Path="HostName" />
          </MultiBinding>
        </TextBlock.Text>
      </TextBlock>
    </StackPanel>

    <!-- ══ Liste des joueurs (US-04) ════════════════════════════════════════ -->
    <Border Grid.Row="1" Background="#0D1520" CornerRadius="8" Padding="16">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Players}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="shared:LobbyPlayerInfo">
              <Border Background="#111827" CornerRadius="6" Padding="12,10" Margin="0,0,0,6">
                <Grid ColumnDefinitions="Auto,12,*">

                  <!-- Indicateur coloré du vaisseau (US-05) -->
                  <Canvas Grid.Column="0" Width="32" Height="32">
                    <Polygon Points="16,2 4,28 16,22 28,28"
                             Fill="{Binding ColorHex, Converter={x:Static conv:StringToBrushConverter.Instance}}"
                             Stroke="#FFFFFF22" StrokeThickness="1" />
                  </Canvas>

                  <!-- Pseudo du joueur -->
                  <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Pseudo}"
                               Foreground="White"
                               FontSize="16"
                               VerticalAlignment="Center" />
                    <Border IsVisible="{Binding IsHost}"
                            Background="#2E496F"
                            CornerRadius="4"
                            Padding="6,2"
                            VerticalAlignment="Center">
                      <TextBlock Text="HÔTE" Foreground="#EAF4FF" FontSize="11" FontWeight="Bold" />
                    </Border>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <!-- ══ Compte à rebours (US-06) ══════════════════════════════════════ -->
    <Border Grid.Row="2" Margin="0,16,0,0" HorizontalAlignment="Center">
      <StackPanel HorizontalAlignment="Center" Spacing="4">

        <!-- Message d'attente ou compte à rebours -->
        <TextBlock Text="{Binding CountdownText}"
                   FontSize="48"
                   FontWeight="Bold"
                   Foreground="#00CFFF"
                   HorizontalAlignment="Center">
          <TextBlock.Transitions>
            <Transitions>
              <DoubleTransition Property="Opacity" Duration="0:0:0.3" />
            </Transitions>
          </TextBlock.Transitions>
        </TextBlock>

        <!-- Barre visuelle du compte à rebours (5 segments fixes) -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4"
                    IsVisible="{Binding IsCountingDown}">
          <Border Width="40" Height="6" CornerRadius="3"
                  Background="{Binding CountdownSeconds, Converter={x:Static conv:CountdownSegmentConverter.Instance},
                               ConverterParameter='0'}" />
          <Border Width="40" Height="6" CornerRadius="3"
                  Background="{Binding CountdownSeconds, Converter={x:Static conv:CountdownSegmentConverter.Instance},
                               ConverterParameter='1'}" />
          <Border Width="40" Height="6" CornerRadius="3"
                  Background="{Binding CountdownSeconds, Converter={x:Static conv:CountdownSegmentConverter.Instance},
                               ConverterParameter='2'}" />
          <Border Width="40" Height="6" CornerRadius="3"
                  Background="{Binding CountdownSeconds, Converter={x:Static conv:CountdownSegmentConverter.Instance},
                               ConverterParameter='3'}" />
          <Border Width="40" Height="6" CornerRadius="3"
                  Background="{Binding CountdownSeconds, Converter={x:Static conv:CountdownSegmentConverter.Instance},
                               ConverterParameter='4'}" />
        </StackPanel>

        <Button Content="LANCER EN SOLO"
                Command="{Binding StartSoloCommand}"
                IsVisible="{Binding CanStartSolo}"
                HorizontalAlignment="Center"
                Margin="0,12,0,0"
                Background="#00CFFF"
                Foreground="#0A0A1A"
                FontWeight="Bold"
                Padding="18,8"
                CornerRadius="4" />

      </StackPanel>
    </Border>

  </Grid>
</UserControl>
